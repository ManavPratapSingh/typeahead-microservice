PORT=3000

# PostgreSQL Configuration
PG_USER=postgres
PG_PASSWORD=postgrespassword
PG_HOST=localhost
PG_PORT=5433
PG_DATABASE=typeahead

# Redis Shards (comma-separated URLs for consistent hashing)
REDIS_SHARDS=redis://localhost:6379/0,redis://localhost:6379/1,redis://localhost:6379/2

# Hybrid Sampling Thresholds
SAMPLING_PER_QUERY_X=5
SAMPLING_GLOBAL_BATCH_G=20

# Linear Decay Settings
DECAY_INTERVAL_SEC=120
DECAY_AMOUNT=2
